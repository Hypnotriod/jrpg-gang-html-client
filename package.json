{
    "name": "jrpg-gang-html-client",
    "author": "Ilya Pikin",
    "version": "0.0.1",
    "license": "ISC",
    "main": "src/index.ts",
    "registry": "https://registry.npmjs.org",
    "scripts": {
        "start-dev": "webpack-cli serve --mode development --config webpack.config.js --env gameServerWsUrl=ws://localhost:3000/ws configurationUrl=http://localhost:3000/configuration authUrl=http://localhost:3000/google/oauth2 authGuestUrl=http://localhost:3000/guest/auth version=0",
        "start-dev-tls": "webpack-cli serve --https-request-cert --https-key ./key.pem --https-cert ./cert.pem --mode development --config webpack.config.js --env gameServerWsUrl=wss://localhost:3000/ws configurationUrl=https://localhost:3000/configuration authUrl=https://localhost:3000/google/oauth2 authGuestUrl=https://localhost:3000/guest/auth version=0",
        "build-prod": "webpack --mode production --config webpack.config.js --env gameServerWsUrl=wss://the_host_name/ws authUrl=https://the_host_name/google/oauth2 authGuestUrl=https://the_host_name/guest/auth configurationUrl=ws://the_host_name/configuration version=version_number"
    },
    "dependencies": {
        "@types/howler": "^2.2.12",
        "@types/html-to-text": "^9.0.4",
        "howler": "^2.2.4",
        "html-to-text": "^9.0.5",
        "local-storage": "^2.0.0",
        "query-string": "^9.1.1",
        "reflect-metadata": "^0.2.2",
        "ts-key-enum": "^3.0.13",
        "tsyringe": "^4.10.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/plugin-transform-runtime": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@types/local-storage": "^2.0.0",
        "@types/query-string": "^6.3.0",
        "babel-loader": "^10.1.1",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^14.0.0",
        "html-webpack-plugin": "^5.6.7",
        "string-replace-loader": "^3.3.0",
        "ts-keycode-enum": "^1.0.6",
        "ts-loader": "^9.6.0",
        "tsc": "^2.0.4",
        "tslint": "^6.1.3",
        "typescript": "^5.9.3",
        "webpack": "^5.107.2",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.4"
    }
}
