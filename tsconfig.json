{
    "compilerOptions": {
        "rootDir": "./",
        "outDir": "./dist/",
        "sourceMap": true,
        "module": "commonjs",
        "target": "es2021",
        "strictPropertyInitialization": false,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "resolveJsonModule": true,
        "strictNullChecks": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts"
    ]
}